# 115 影视资源共享平台 - 用户安装配置

# --- 数据库 ---
POSTGRES_USER=115share
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=115share
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- 端口 ---
BACKEND_HOST_PORT=8115
ADMIN_HOST_PORT=5115
MEMBER_HOST_PORT=5116

# --- 管理后台 ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_admin_password
JWT_SECRET=change_me_random_very_long_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# --- 115 网盘 ---
115_COOKIE=
ARCHIVE_DIR_ID=

# --- TMDB ---
TMDB_API_KEY=
TMDB_LANGUAGE=zh-CN
TMDB_REGION=CN

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_SERVICE_BOT_TOKEN=
TELEGRAM_NOTIFY_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

# --- 代理（可选） ---
PROXY_ENABLED=false
PROXY_HTTP=

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# --- 调度 ---
SHARE_PENDING_INTERVAL=60
API_DELAY_SECONDS=2.0
API_TIMEOUT_SECONDS=15.0

# --- 日志与缓存 ---
LOG_LEVEL=INFO
LOG_FILE=data/logs/app.log
POSTER_CACHE_DIR=data/posters

# --- 授权安装 ---
LICENSE_SERVER=http://119.45.226.217:5002
LICENSE_CODE=
LICENSE_PROJECT_NAME=115-sharing-platform
LICENSE_REQUIRED=true

# --- 跨域 ---
# 局域网使用 IP 访问一般无需修改；如接入域名，把域名加进来。
CORS_ALLOWED_ORIGINS=http://localhost:5115,http://localhost:5116
